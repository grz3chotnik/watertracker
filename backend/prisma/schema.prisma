generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String       @id // Clerk user ID
  email     String       @unique
  limit     Int          @default(150)
  createdAt DateTime     @default(now())
  entries   WaterEntry[]
}

model WaterEntry {
  id        String   @id @default(uuid())
  date      String
  amount    Float
  type      String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
